{
  "name": "tamsi",
  "version": "0.0.8",
  "description": "Lightweight micro-engine for explicit h3-based servers.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": {
    "tamsi": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "unbuild",
    "tamsi": "node dist/cli.mjs",
    "test": "vitest run"
  },
  "keywords": [
    "h3",
    "router"
  ],
  "author": "John Jerald De Chavez",
  "license": "MIT",
  "dependencies": {
    "c12": "4.0.0-beta.4",
    "chokidar": "^5.0.0",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "esbuild": "^0.28.0",
    "h3": "2.0.1-rc.20",
    "hookable": "^6.1.0",
    "jiti": "^2.6.1",
    "listhen": "^1.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.2"
  }
}